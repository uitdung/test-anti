{
  "name": "md-to-rules-sync",
  "displayName": "MD to Rules Sync",
  "description": "Sync markdown files to .agents/rules or CLAUDE.md for Antigravity/Claude Code",
  "version": "0.3.0",
  "publisher": "local",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mdToRules",
          "title": "MD to Rules",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "mdToRules": [
        {
          "id": "mdToRulesSidebar",
          "name": "Markdown Files",
          "icon": "resources/icon.svg",
          "contextualTitle": "MD to Rules Sync"
        }
      ]
    },
    "configuration": {
      "title": "MD to Rules Sync",
      "properties": {
        "mdToRules.sourceFolder": {
          "type": "string",
          "default": ".agents/memory",
          "description": "Source folder containing markdown files"
        },
        "mdToRules.defaultSyncMode": {
          "type": "string",
          "enum": [
            "rules",
            "claude",
            "both"
          ],
          "default": "rules",
          "description": "Default sync destination"
        },
        "mdToRules.claudeFilePath": {
          "type": "string",
          "default": "CLAUDE.md",
          "description": "Path to CLAUDE.md file (relative to workspace)"
        },
        "mdToRules.rulesFolder": {
          "type": "string",
          "default": ".agents/rules",
          "description": "Destination folder for rules"
        }
      }
    },
    "commands": [
      {
        "command": "mdToRules.refresh",
        "title": "Refresh Files",
        "icon": "$(refresh)"
      },
      {
        "command": "mdToRules.toggleFile",
        "title": "Toggle File Sync"
      },
      {
        "command": "mdToRules.syncAll",
        "title": "Sync All Enabled Files",
        "icon": "$(sync)"
      },
      {
        "command": "mdToRules.openFile",
        "title": "Open File"
      },
      {
        "command": "mdToRules.createFile",
        "title": "Create New File",
        "icon": "$(add)"
      },
      {
        "command": "mdToRules.selectSourceFolder",
        "title": "Select Source Folder"
      },
      {
        "command": "mdToRules.changeSyncMode",
        "title": "Change Sync Mode"
      },
      {
        "command": "mdToRules.setFolderFromExplorer",
        "title": "Set as MD Source Folder"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "mdToRules.refresh",
          "when": "view == mdToRulesSidebar",
          "group": "navigation"
        },
        {
          "command": "mdToRules.syncAll",
          "when": "view == mdToRulesSidebar",
          "group": "navigation"
        },
        {
          "command": "mdToRules.createFile",
          "when": "view == mdToRulesSidebar",
          "group": "navigation"
        },
        {
          "command": "mdToRules.selectSourceFolder",
          "when": "view == mdToRulesSidebar",
          "group": "2_options@1"
        }
      ],
      "view/item/context": [
        {
          "command": "mdToRules.toggleFile",
          "when": "view == mdToRulesSidebar",
          "group": "inline@1"
        },
        {
          "command": "mdToRules.openFile",
          "when": "view == mdToRulesSidebar",
          "group": "1_actions@1"
        },
        {
          "command": "mdToRules.changeSyncMode",
          "when": "view == mdToRulesSidebar",
          "group": "1_actions@2"
        },
        {
          "command": "mdToRules.showHelp",
          "when": "view == mdToRulesSidebar",
          "group": "2_help@1"
        }
      ],
      "explorer/context": [
        {
          "command": "mdToRules.setFolderFromExplorer",
          "when": "explorerResourceIsFolder",
          "group": "2_workspace@1"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^8.0.0",
    "typescript": "^5.0.0"
  }
}